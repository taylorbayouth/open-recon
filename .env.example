# Provider credentials. Copy to `.env` and fill in the key for the provider you
# use. Only the key for your active provider is required — ollama needs none.
#
# Pick the active provider with --provider or BROWSER_AGENT_PROVIDER (default:
# openai, see browser-agent.config.json). The vision model can use a different
# provider, so you may need more than one key.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ─── Optional ─────────────────────────────────────────────────────────────────
# Everything below has a working default; uncomment only to override.

# Point a provider at an OpenAI/Anthropic/Gemini-compatible gateway instead of
# its official endpoint.
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Local Ollama server (no API key needed).
# OLLAMA_HOST=http://localhost:11434
