{
  "name": "browser-agent",
  "version": "1.2.3",
  "description": "Extract interactive elements and text from a live Chrome tab via CDP. No JS injection. No DOM mutations.",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "browser-agent": "./agent.js",
    "browser-agent-extract": "./cli.js"
  },
  "scripts": {
    "start": "node agent.js",
    "launch": "node launch.js",
    "extract": "node cli.js --tree --pretty",
    "agent": "node agent.js",
    "test": "node test/agent.test.js && node test/test.js",
    "test:e2e": "BROWSER_AGENT_E2E=1 node test/test.js && BROWSER_AGENT_E2E=1 node test/selectText.test.js",
    "test:agent": "node test/agent.test.js",
    "bench": "node bench.js"
  },
  "keywords": [
    "cdp",
    "chrome",
    "devtools",
    "accessibility",
    "dom",
    "scraping",
    "browser-automation",
    "llm",
    "agent"
  ],
  "author": "Taylor Bayouth",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/taylorbayouth/browser-agent.git"
  },
  "type": "commonjs",
  "dependencies": {
    "chrome-remote-interface": "^0.34.0",
    "dotenv": "^17.4.2"
  }
}
