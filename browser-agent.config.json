{
  "provider": "openai",
  "model": "gpt-5.4-mini",
  "reasoningEffort": "medium",

  "loop": {
    "maxSteps": 100,
    "shortCircuitOnNoChange": true,
    "pollMs": 1500,
    "maxNoChangePolls": 3,
    "maxStuckRepeats": 2,
    "maxEmptyPlans": 1,
    "maxUrlVisits": 4,
    "revisitUrlMatch": "clean",
    "maxSparsePageRetries": 4,
    "sparsePageRetryMs": 400,
    "sparsePageMinNodes": 2,
    "maxSameDirectionScrolls": 3,
    "maxScrollReversals": 3
  },

  "reflect": {
    "enabled": true,
    "provider": "openai",
    "model": "gpt-5.5",
    "maxReflections": 10,
    "cooldownTurns": 4,
    "budgetTurnFraction": 0.6,
    "savedMaxChars": 16000
  },

  "settle": {
    "afterActionMs": 150,
    "maxMs": 2000
  },

  "view": {
    "includeText": true,
    "includeCoords": true,
    "maxTextChars": 200,
    "dedupeText": true
  },

  "executor": {
    "backend": "os",
    "binPath": null,
    "pauseOnUserInput": true,
    "userIdleMs": 600,
    "raiseChromeOnStart": true,
    "humanize": {
      "enabled": true,
      "mouseSpeedPxPerSec": 1400,
      "mouseJitterPx": 4,
      "keystrokeDelayMsMin": 25,
      "keystrokeDelayMsMax": 85,
      "postFocusPauseMs": 80,
      "postClearPauseMs": 50,
      "preClickPauseMsMin": 40,
      "preClickPauseMsMax": 160,
      "scrollDurationMs": 400,
      "scrollJitterPx": 4
    }
  },

  "vision": {
    "provider": "openai",
    "model": "gpt-5.4-mini",
    "prompt": "Describe what you see in detail. Aim for 1500-2000 characters.",
    "maxTokens": 1024
  },

  "log": {
    "enabled": true,
    "dir": "logs"
  }
}
