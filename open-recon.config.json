{
  "provider": "openai",
  "model": "gpt-5.4-mini",

  "loop": {
    "maxSteps": 50,
    "shortCircuitOnNoChange": true,
    "pollMs": 1500,
    "maxNoChangePolls": 10,
    "maxEmptyPlans": 3
  },

  "settle": {
    "afterActionMs": 150,
    "maxMs": 2000
  },

  "view": {
    "includeText": true,
    "includeCoords": true,
    "maxTextChars": 200,
    "dedupeText": true
  },

  "executor": {
    "backend": "os",
    "binPath": null,
    "humanize": {
      "enabled": true,
      "mouseSpeedPxPerSec": 1400,
      "mouseJitterPx": 2,
      "keystrokeDelayMsMin": 25,
      "keystrokeDelayMsMax": 85,
      "preClickPauseMsMin": 40,
      "preClickPauseMsMax": 160,
      "scrollDurationMs": 400,
      "scrollJitterPx": 3
    }
  },

  "log": {
    "enabled": true,
    "dir": "logs"
  }
}
