# Provider credentials. Copy to `.env` and fill in the key for the provider you
# use. The default provider is `openai` (see open-recon.config.json) — set
# OPENAI_API_KEY for it, or switch providers with --provider / OPEN_RECON_PROVIDER.
#
# Only the key for your active provider is required. ollama needs none.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: point a provider at an OpenAI/Anthropic-compatible gateway.
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: local Ollama server (default http://localhost:11434).
# OLLAMA_HOST=http://localhost:11434
