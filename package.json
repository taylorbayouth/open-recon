{
  "name": "open-recon",
  "version": "1.1.1",
  "description": "Extract interactive elements and text from a live Chrome tab via CDP. No JS injection. No DOM mutations.",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "open-recon": "./agent.js",
    "open-recon-extract": "./cli.js"
  },
  "scripts": {
    "start": "node agent.js",
    "launch": "node launch.js",
    "extract": "node cli.js --tree --pretty",
    "agent": "node agent.js",
    "test": "node test/agent.test.js && node test/test.js",
    "test:e2e": "OPEN_RECON_E2E=1 node test/test.js && OPEN_RECON_E2E=1 node test/selectText.test.js",
    "test:agent": "node test/agent.test.js"
  },
  "keywords": [
    "cdp",
    "chrome",
    "devtools",
    "accessibility",
    "dom",
    "scraping",
    "browser-automation",
    "llm",
    "agent"
  ],
  "author": "Taylor Bayouth",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/taylorbayouth/open-recon.git"
  },
  "type": "commonjs",
  "dependencies": {
    "chrome-remote-interface": "^0.34.0",
    "dotenv": "^17.4.2"
  }
}
